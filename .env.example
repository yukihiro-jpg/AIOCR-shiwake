# ============================================================
# 静的サイト（GitHub Pages）版の設定
# ============================================================
# このアプリは静的サイトとしてブラウザだけで動作します（サーバー不要）。
# 以下は「ビルド時」に埋め込まれる公開値です（秘密情報ではありません）。
# GitHub Actions では Settings → Variables に登録した値が使われます。
# ローカルで静的ビルドを試す場合のみ .env.local に設定してください。

# クライアント側 OAuth のクライアントID（〜.apps.googleusercontent.com）
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# 保存先の親フォルダ / 共有ドライブの ID
NEXT_PUBLIC_GOOGLE_DRIVE_FOLDER_ID=your_root_folder_id

# 保存フォルダ名（任意。既定: 事務所アプリ共有データ）
# NEXT_PUBLIC_GOOGLE_DRIVE_DATA_FOLDER_NAME=事務所アプリ共有データ

# プロジェクトページ配下に置く場合の basePath（GitHub Actions が自動設定）
# 例: /aiocr-shiwake
# NEXT_PUBLIC_BASE_PATH=/aiocr-shiwake

# ※ Gemini API キーはコードに埋め込みません。
#    各ユーザーが画面の「Gemini APIキー設定」から入力し、各自のブラウザに保存します。
